# Production build env. Vite auto-loads .env.production when mode === 'production'
# (which is what `npm run build` defaults to). This file makes a clean-checkout
# manual deploy work without needing to remember the env-prefix incantation.
#
# Source of truth still lives in two places that must stay in sync:
#   1. .github/workflows/frontend-deploy.yml — the CI deploy
#   2. this file — the manual deploy
# If the API CloudFront distribution or WebSocket API id ever changes, both
# need to be updated. The README documents these as the canonical URLs.
VITE_API_URL=https://d17hrttnkrygh8.cloudfront.net
VITE_WS_URL=wss://cw8v5hucna.execute-api.us-east-1.amazonaws.com/production
VITE_HIDE_DEMO_BADGES=false
