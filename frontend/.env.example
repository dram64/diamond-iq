# Diamond IQ frontend environment.
# Copy to .env.local for developer-specific overrides (gitignored).
#
# Production traffic flows through a CloudFront distribution that has a
# WAFv2 Web ACL attached (managed rule groups, rate limiting, bad-bot
# blocking). The frontend points at the CloudFront URL, never the direct
# API Gateway URL. See docs/adr/010 for design rationale.

# Base URL of the backend HTTP API. No trailing slash.
# Production CloudFront URL is in .env.development (committed).
VITE_API_URL=https://your-cloudfront-id.cloudfront.net

# WebSocket entry point for real-time score updates. The browser opens a
# wss:// connection here, sends {action: "subscribe", game_pk: N} messages,
# and receives score_update payloads pushed from the stream-processor.
# See docs/adr/011 for the design rationale.
VITE_WS_URL=wss://your-ws-id.execute-api.us-east-1.amazonaws.com/production

# When "true", suppresses the "Demo data" badges on sections that still
# render mock data (insights, leaderboards, hardest-hit, compare, team
# grid, LiveGamePage tabs other than the header). Use for clean
# screenshots; leave "false" for normal development.
VITE_HIDE_DEMO_BADGES=false
