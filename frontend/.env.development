# In dev mode the frontend uses RELATIVE URLs and Vite proxies API paths
# to CloudFront server-side (see vite.config.ts server.proxy block). This
# bypasses the API Gateway's CORS allow-list, which is scoped to the
# production frontend origin only — localhost:5173-5179 would otherwise
# all be blocked. Production builds use VITE_API_URL set in the deploy
# pipeline (typically https://d17hrttnkrygh8.cloudfront.net).
VITE_API_URL=/

# WebSocket entry point for real-time score updates. Pipeline:
# DynamoDB Streams → stream-processor Lambda → API Gateway WebSocket → browser.
# v1 ships without WAF in front of the WS endpoint; see docs/adr/011.
# Browser opens this directly; not proxied via Vite.
VITE_WS_URL=wss://cw8v5hucna.execute-api.us-east-1.amazonaws.com/production

VITE_HIDE_DEMO_BADGES=false
