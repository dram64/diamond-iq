# Production traffic flows through CloudFront for WAF protection.
# The direct API Gateway URL — https://7x9tjaks0d.execute-api.us-east-1.amazonaws.com —
# is preserved as an ops-only debugging bypass and is intentionally NOT wired
# to any frontend code path. See docs/adr/010 (WAF + CloudFront).
VITE_API_URL=https://d17hrttnkrygh8.cloudfront.net

# WebSocket entry point for real-time score updates. Pipeline:
# DynamoDB Streams → stream-processor Lambda → API Gateway WebSocket → browser.
# v1 ships without WAF in front of the WS endpoint; see docs/adr/011.
VITE_WS_URL=wss://cw8v5hucna.execute-api.us-east-1.amazonaws.com/production

VITE_HIDE_DEMO_BADGES=false
